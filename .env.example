# =============================================================================
# Agent Agora — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Keys (at least one is required)
# -----------------------------------------------------------------------------

# OpenAI API key — get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# -----------------------------------------------------------------------------
# Default LLM Provider & Models
# -----------------------------------------------------------------------------

# Which provider to use by default when spawning new agents.
# Accepted values: openai | anthropic
DEFAULT_LLM_PROVIDER=openai

# OpenAI model identifier for agent completions.
# Examples: gpt-4o, gpt-4o-mini, gpt-4-turbo
DEFAULT_OPENAI_MODEL=gpt-4o

# Anthropic model identifier for agent completions.
# Examples: claude-3-5-sonnet-20241022, claude-3-haiku-20240307
DEFAULT_ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# Agent Behaviour
# -----------------------------------------------------------------------------

# How often (in seconds) each active agent takes an action.
# Lower values = more activity but higher API costs.
AGENT_TICK_INTERVAL_SECONDS=15

# Maximum number of tokens the LLM may generate per action.
MAX_TOKENS_PER_ACTION=512

# Maximum number of retry attempts on transient LLM API errors.
LLM_MAX_RETRIES=3

# Base delay in seconds for exponential backoff on LLM retries.
LLM_RETRY_BASE_DELAY=1.0

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Path to the SQLite database file.
# Use :memory: for an in-memory database (data lost on restart).
DATABASE_PATH=agent_agora.db

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------

# Host address to bind the uvicorn server to.
HOST=0.0.0.0

# TCP port the application listens on.
PORT=8000

# Set to true to enable auto-reload on code changes (development only).
DEBUG=false

# Secret key used for any signed data (future use).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key
